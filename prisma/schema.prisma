// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  
}

enum PropertyType {
  CONDO
  HOUSE_AND_LOT
  LOT_ONLY
  TOWNHOUSE
  COMMERCIAL
  BEACH_VACATION
}

enum PropertyStatus {
  FOR_SALE
  FOR_RENT
  PRE_SELLING
  SOLD
  RENTED
}

enum ListingType {
  BRAND_NEW
  RESALE
}

enum PaymentSchemeType {
  SPOT_CASH
  IN_HOUSE_FINANCING
  BANK_FINANCING
  PAG_IBIG_FINANCING
  RENT_TO_OWN
}

enum Role {
  ADMIN
  CLIENT
}

model Profile {
  id          String   @id 
  email       String   @unique
  fullName    String?
  avatarUrl   String?
  role        Role     @default(CLIENT)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("profiles")
}

model Property {
  id                    String                  @id @default(uuid())
  title                 String
  slug                  String                  @unique
  description           String
  type                  PropertyType
  status                PropertyStatus
  listingType           ListingType             @default(BRAND_NEW)
  isFeatured            Boolean                 @default(false)
  address               String
  city                  String                  @default("Cebu City")
  barangay              String?
  latitude              Float?
  longitude             Float?
  price                 Float?
  priceLabel            String?
  lotArea               Float?
  floorArea             Float?
  bedrooms              Int?
  bathrooms             Int?
  parking               Int?                    @default(0)
  monthlyRent           Float?
  associationDue        Float?
  floorLevel            String?
  totalFloors           Int?
  beachFrontage         Float?
  hasDock               Boolean                 @default(false)
  isTourismZoned        Boolean                 @default(false)
  isAirbnbReady         Boolean                 @default(false)
  isPagibigAccredited   Boolean                 @default(false)
  isBankFinancingReady  Boolean                 @default(false)
  isInHouseFinancing    Boolean                 @default(false)
  isRentToOwn           Boolean                 @default(false)
  developerName         String?
  projectPhase          String?
  expectedTurnover      String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  deletedAt             DateTime?
  images                PropertyImage[]
  amenities             PropertyAmenity[]
  units                 PropertyUnit[]
  paymentSchemes        PropertyPaymentScheme[]
  landmarks             PropertyLandmark[]

  @@index([city])
  @@index([type, status])
  @@index([isFeatured])
  @@index([deletedAt])

  @@map("properties")
}

model PropertyUnit {
  id                  String          @id @default(uuid())
  propertyId          String
  label               String
  status              PropertyStatus?
  price               Float?
  priceLabel          String?
  floorArea           Float?
  lotArea             Float?
  bedrooms            Int?
  bathrooms           Int?
  parking             Int?            @default(0)
  towerOrPhase        String?
  floorPlanImage      String?
  floorPlanPublicId   String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  property            Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("property_units")
}

model PropertyImage {
  id          String    @id @default(uuid())
  propertyId  String
  url         String
  publicId    String
  isPrimary   Boolean   @default(false)
  order       Int       @default(0)
  caption     String?
  createdAt   DateTime  @default(now())
  property    Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("property_images")
}

model Amenity {
  id              String              @id @default(uuid())
  name            String              
  nameNormalized  String              @unique 
  icon            String?
  createdAt       DateTime            @default(now())
  properties      PropertyAmenity[]

  @@map("amenities")
}

model PropertyAmenity {
  id          String    @id @default(uuid())
  propertyId  String
  amenityId   String
  property    Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  amenity     Amenity   @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@unique([propertyId, amenityId])
  @@index([propertyId])
  @@map("property_amenities")
}

model PaymentScheme {
  id            String                  @id @default(uuid())
  type          PaymentSchemeType
  name          String                  
  description   String?
  downPayment   Float?
  monthlyAmount Float?
  terms         Int?
  interestRate  Float?
  createdAt     DateTime                @default(now())
  properties    PropertyPaymentScheme[]

  @@unique([type, name])
  @@map("payment_schemes")
}

model PropertyPaymentScheme {
  id              String        @id @default(uuid())
  propertyId      String
  paymentSchemeId String
  property        Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  paymentScheme   PaymentScheme @relation(fields: [paymentSchemeId], references: [id], onDelete: Cascade)

  @@unique([propertyId, paymentSchemeId])
  @@index([propertyId])
  @@map("property_payment_schemes")
}

model Landmark {
  id              String              @id @default(uuid())
  name            String             
  nameNormalized  String              @unique
  category        String?             
  createdAt       DateTime            @default(now())
  properties      PropertyLandmark[]

  @@map("landmarks")
}

model PropertyLandmark {
  id          String    @id @default(uuid())
  propertyId  String
  landmarkId  String
  distance    String?   
  property    Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  landmark    Landmark  @relation(fields: [landmarkId], references: [id], onDelete: Cascade)

  @@unique([propertyId, landmarkId])
  @@index([propertyId])
  @@map("property_landmarks")
}

model Blog {
  id                String        @id @default(uuid())
  title             String
  slug              String        @unique
  content           Json
  excerpt           String
  coverImage        String?
  coverPublicId     String?
  isPublished       Boolean       @default(false)
  isAiGenerated     Boolean       @default(false)
  publishedAt       DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  deletedAt         DateTime?
  metaTitle         String?
  metaDescription   String?
  tags              TagsOnBlogs[]

  @@map("blogs")
}

model BlogTag {
  id    String        @id @default(uuid())
  name  String        @unique
  slug  String        @unique
  blogs TagsOnBlogs[]

  @@map("blog_tags")
}

model TagsOnBlogs {
  blogId  String
  tagId   String
  blog    Blog    @relation(fields: [blogId], references: [id], onDelete: Cascade)
  tag     BlogTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([blogId, tagId])
  @@map("tags_on_blogs")
}